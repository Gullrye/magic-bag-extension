{
  "name": "magic-bag",
  "version": "1.0.0",
  "description": "一键收纳标签页，让浏览器保持清爽",
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.5.0",
    "wxt": "^0.20.20"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.38",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.1",
    "@wxt-dev/module-react": "^1.1.3",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  }
}
