{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "~/": ["./*"],
      "~/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".wxt/**/*.d.ts"],
  "exclude": ["node_modules", ".output", "dist"]
}
